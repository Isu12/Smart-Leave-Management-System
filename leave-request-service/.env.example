PORT=5001
USE_IN_MEMORY_DB=false
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?appName=Cluster0

# Must match Auth & User Service JWT_SECRET for token verification
JWT_SECRET=your_jwt_secret_here

# Optional: shared secret for server-to-server calls (e.g. Auth service login leave check).
# Set the same value as LEAVE_SERVICE_API_KEY in Auth & User Service.
SERVICE_API_KEY=
