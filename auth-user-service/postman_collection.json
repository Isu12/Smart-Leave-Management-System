{
  "info": {
    "name": "Auth & User Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "http://localhost:5000/auth/register", "host": ["localhost"], "port": "5000", "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"EMPLOYEE\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "http://localhost:5000/auth/login", "host": ["localhost"], "port": "5000", "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User (Manager)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "http://localhost:5000/users", "host": ["localhost"], "port": "5000", "path": ["users"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"Manager$2024\",\n  \"role\": \"MANAGER\"\n}"
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "http://localhost:5000/users", "host": ["localhost"], "port": "5000", "path": ["users"] }
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "http://localhost:5000/users/:id", "host": ["localhost"], "port": "5000", "path": ["users", ":id"], "variable": [{"key":"id","value":"<USER_ID>"}] }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "http://localhost:5000/users/:id", "host": ["localhost"], "port": "5000", "path": ["users", ":id"], "variable": [{"key":"id","value":"<USER_ID>"}] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith Updated\"\n}"
            }
          }
        },
        {
          "name": "Soft Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "http://localhost:5000/users/:id", "host": ["localhost"], "port": "5000", "path": ["users", ":id"], "variable": [{"key":"id","value":"<USER_ID>"}] }
          }
        }
      ]
    }
  ]
}
